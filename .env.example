# Local-dev placeholders. Real values live in Netlify → Site settings → Environment variables.
# Copy this file to `.env` and fill in if you want to test functions locally with `netlify dev`.

# Google reCAPTCHA v3 secret (https://www.google.com/recaptcha/admin)
RECAPTCHA_SECRET=

# Public site key for reCAPTCHA v3 — gets injected into the page HTML at deploy time.
RECAPTCHA_SITE_KEY=

# HubSpot Private App bearer token (Settings → Integrations → Private Apps).
# Required scopes: crm.objects.contacts.read, crm.objects.contacts.write
HUBSPOT_TOKEN=

# Google Analytics 4 measurement ID (G-XXXXXXXXXX). Replaces __GA4_MEASUREMENT_ID__ in HTML at deploy.
GA4_MEASUREMENT_ID=

# Cookiebot ID (the data-cbid value). Replaces __COOKIEBOT_CBID__ in HTML at deploy.
COOKIEBOT_CBID=
